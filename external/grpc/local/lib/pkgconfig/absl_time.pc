prefix=/Users/matthewhvizdos/Desktop/COE892/Hospital_Management/external/grpc/local
exec_prefix=${prefix}
libdir=/Users/matthewhvizdos/Desktop/COE892/Hospital_Management/external/grpc/local/lib
includedir=/Users/matthewhvizdos/Desktop/COE892/Hospital_Management/external/grpc/local/include

Name: absl_time
Description: Abseil time library
URL: https://abseil.io/
Version: 20250512
Requires: absl_base = 20250512, absl_civil_time = 20250512, absl_core_headers = 20250512, absl_int128 = 20250512, absl_raw_logging_internal = 20250512, absl_strings = 20250512, absl_time_zone = 20250512
Libs: -L${libdir}  -labsl_time 
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -DNOMINMAX
