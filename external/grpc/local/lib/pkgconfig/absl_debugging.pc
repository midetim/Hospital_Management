Name: absl_debugging
Description: Abseil debugging library
URL: https://abseil.io/
Version: 20250512
Requires: absl_stacktrace = 20250512, absl_leak_check = 20250512
Libs: -L${libdir}  
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -DNOMINMAX
