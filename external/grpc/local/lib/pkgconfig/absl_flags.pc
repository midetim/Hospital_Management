Name: absl_flags
Description: Abseil flags library
URL: https://abseil.io/
Version: 20250512
Requires: absl_config = 20250512, absl_flags_commandlineflag = 20250512, absl_flags_config = 20250512, absl_flags_internal = 20250512, absl_flags_reflection = 20250512, absl_core_headers = 20250512, absl_nullability = 20250512, absl_strings = 20250512
Libs: -L${libdir}  
Cflags: -I${includedir} -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -DNOMINMAX
